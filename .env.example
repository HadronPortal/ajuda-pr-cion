# Chave server-side do monitor SEFAZ da FiscalAPI.
# Cadastre-se em https://app.fiscalapi.com.br e nunca use o prefixo VITE_.
FISCAL_API_KEY=fapi_sua_chave_aqui

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Conexao privada usada somente pelas Server Functions. Nunca use o prefixo VITE_.
DATABASE_URL=postgresql://postgres.project-ref:password@host:5432/postgres
